# ── Truvi server environment ────────────────────────────────────────────────

# Supabase (Postgres) connection string — the single datastore for the whole
# app. Get it from Supabase → Project Settings → Database → Connection string.
# Use the "Transaction" pooler URL (port 6543) for deployments. Required in
# production; the server refuses to boot without it.
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# JWT signing secrets (generate with: openssl rand -base64 32)
JWT_ACCESS_SECRET=change-me
JWT_REFRESH_SECRET=change-me

# Server
NODE_ENV=development
PORT=5000
# Comma-separated allow-list of frontend origins for CORS + the auth cookie.
# In production this MUST be your deployed frontend's exact origin.
CLIENT_URL=http://localhost:5173

# Public base URL of THIS API (used to build absolute upload URLs). On Render,
# RENDER_EXTERNAL_URL is provided automatically and used as a fallback.
# PUBLIC_URL=https://your-api.onrender.com

# Optional integrations — the app degrades gracefully if these are unset.
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=

# Where uploaded files are written. Defaults to server/uploads. On Render, set
# this to a persistent Disk mount (e.g. /var/data/uploads) to survive redeploys.
# UPLOAD_DIR=
