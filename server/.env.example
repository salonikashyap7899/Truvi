# ── Core ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/postgres
JWT_ACCESS_SECRET=change-me
JWT_REFRESH_SECRET=change-me
NODE_ENV=development
PORT=5000
HOST=0.0.0.0
CLIENT_URL=http://localhost:5173
PUBLIC_URL=http://localhost:5000
UPLOAD_DIR=

# ── Razorpay ────────────────────────────────────────────────────────────
# Start with TEST keys (Dashboard → Settings → API Keys, in Test Mode).
# Switch to the rzp_live_* keys only after you've verified a test payment.
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_test_key_secret
# Dashboard → Settings → Webhooks → the secret you set when creating the webhook.
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret
# GST added on top of every price (India default 18%). Configurable.
GST_PERCENT=18

# ── Founder (CEO OS) accounts ───────────────────────────────────────────
# Truvi's two founders (Sandeep & Meraj) are auto-provisioned as ADMIN-role
# accounts on boot so /founder/dashboard is reachable on a fresh deploy without
# seeding. Set each founder's real email + password below. To change an EXISTING
# founder's email/password on a live deploy, run:  cd server && npm run founders
# (the boot path only creates missing accounts; it never resets a live login).
FOUNDER1_NAME=Sandeep
FOUNDER1_EMAIL=sandeep@truviventures.com
FOUNDER1_PASSWORD=
FOUNDER2_NAME=Meraj
FOUNDER2_EMAIL=meraj@truviventures.com
FOUNDER2_PASSWORD=
# Optional shared fallback if a founder has no dedicated password above.
FOUNDER_PASSWORD=

# ── Developer OS test access (no payment) ───────────────────────────────
# Admins always see the developer workspace fully unlocked. To also give a
# developer account a free full pass, list its email(s) here (comma-separated).
DEV_UNLOCK_EMAILS=
# Or unlock every paid developer tool for ALL developers (staging/test only).
DEV_UNLOCK_ALL=false

# ── Email / SMS (existing) ──────────────────────────────────────────────
# SMTP settings used by emailService for OTP + payment confirmations.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Truvi <info@truviventures.com>
