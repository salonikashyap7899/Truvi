# MongoDB — must be a replica set for commission generation's multi-document
# transaction to work. Local: run `mongod --replSet rs0` then `mongosh --eval "rs.initiate()"`.
# Or use MongoDB Atlas, which is a replica set by default.
MONGO_URI="mongodb://localhost:27017/truvi"

# JWT secrets — generate with: openssl rand -base64 32
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"

PORT=5000
CLIENT_URL="http://localhost:5173"
PUBLIC_URL="http://localhost:5000"
NODE_ENV="development"
# This project deploys as two separate Render/host services (API + a
# separately-hosted frontend) — see README → "Deploying to Render". In that
# setup CLIENT_URL is REQUIRED in production: it's the CORS allow-list
# origin, and the refresh-token cookie's cross-site (SameSite=None) behavior
# depends on it matching your deployed frontend's exact origin.
# PUBLIC_URL is optional — it falls back to Render's auto-injected
# RENDER_EXTERNAL_URL (this API's own URL), which is already correct.
# CLIENT_URL="https://your-frontend.example.com"
# PUBLIC_URL="https://your-backend.example.com"

# Nodemailer — leave blank to use the console/dev transport
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="Truvi <no-reply@truvi.app>"

# Razorpay test mode — leave blank to use simulated payments (no real gateway)
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
