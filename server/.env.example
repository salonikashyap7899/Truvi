### DO NOT COMMIT REAL SECRETS TO SOURCE CONTROL
# Copy this file to `.env` and fill in the real values locally or in your
# hosting environment.

# --- Supabase (PostgreSQL) ---------------------------------------------------
# Drizzle connects over the direct Postgres protocol, so this must be the
# CONNECTION STRING (with your database password), NOT the API keys.
# Find it: Supabase dashboard -> Project Settings -> Database ->
# Connection string -> URI tab -> "Transaction pooler" (port 6543).
DATABASE_URL="postgresql://postgres.<project-ref>:<db-password>@aws-0-<region>.pooler.supabase.com:6543/postgres"

# Supabase API keys (used by the React client, not by Drizzle)
SUPABASE_URL=""
SUPABASE_PUBLISHABLE_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
VITE_SUPABASE_PROJECT_ID=""
VITE_SUPABASE_PUBLISHABLE_KEY=""
VITE_SUPABASE_URL=""

# --- Auth --------------------------------------------------------------------
# JWT secrets — generate with: openssl rand -base64 32
JWT_ACCESS_SECRET=""
JWT_REFRESH_SECRET=""

# --- Server ------------------------------------------------------------------
PORT=5001
CLIENT_URL="http://localhost:5000"
PUBLIC_URL="http://localhost:5001"
NODE_ENV="development"

# --- Anthropic — required for Ask Truvi / AI Sales Copilot -------------------
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=""

# --- Nodemailer — leave blank to use the console/dev transport ---------------
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="Truvi <no-reply@truvi.app>"

# --- SMS OTP provider — leave blank to log codes to the console (dev) --------
# The OTP system auto-detects whichever of these is filled in. Add one to
# start sending real SMS; no code change needed.
#   Twilio:
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""
#   or MSG91 (India-focused):
MSG91_AUTH_KEY=""
MSG91_SENDER_ID=""

# --- Razorpay test mode — leave blank to use simulated payments --------------
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
