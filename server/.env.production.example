# ── Truvi production env (single-origin VPS) ────────────────────────────────
# Copy to server/.env on the VPS and fill in real values. Never commit .env.

# Supabase (Postgres) connection string. Use the pooler URL (port 6543).
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:6543/postgres

# JWT secrets — generate each with: openssl rand -base64 32
JWT_ACCESS_SECRET=REPLACE_WITH_RANDOM_32_BYTES
JWT_REFRESH_SECRET=REPLACE_WITH_ANOTHER_RANDOM_32_BYTES

NODE_ENV=production
# Node listens here; nginx proxies to it. Keep it on loopback.
PORT=5000
HOST=127.0.0.1

# Your public site origin (same origin serves API + frontend on a VPS).
CLIENT_URL=https://your-domain.com
PUBLIC_URL=https://your-domain.com

# Single-origin cookie policy: Lax is correct when the frontend and API share
# one domain (works with or without the cross-site None+Secure dance).
COOKIE_SAMESITE=lax
# Leave Secure on once TLS is set up (certbot). Set to false ONLY if you are
# temporarily testing over plain http:// before installing the certificate.
COOKIE_SECURE=true

# Absolute path for uploaded files so it never depends on the working dir.
# Keep it OUTSIDE the git checkout so `git pull` / redeploys never wipe it.
UPLOAD_DIR=/var/www/truvi-uploads

# Optional integrations — the app degrades gracefully if unset.
# ANTHROPIC_API_KEY=       # enables the Ask Truvi AI assistant
# Email (Nodemailer) — powers approval/commission emails, and OTP emails once
# wired. Falls back to logging if unset. NOTE: the password var is SMTP_PASSWORD.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=youraddress@gmail.com
# SMTP_PASSWORD=your_gmail_app_password
# SMTP_FROM=Truvi <youraddress@gmail.com>
#
# Phone OTP via SMS (Twilio). Without these, phone OTP codes are logged, not sent.
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_twilio_auth_token
# TWILIO_FROM=+14155552671            # a Twilio number in E.164 format
#
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
