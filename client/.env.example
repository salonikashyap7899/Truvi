# Local dev value below. In production this REQUIRES a real value — the API
# is deployed as its own separate Render service (see root README.md →
# "Deploying to Render"), so there's no same-origin fallback to rely on. Set
# this at build time (wherever the frontend is hosted) to the deployed API's
# exact URL, e.g. VITE_API_URL="https://truvi-api.onrender.com"
VITE_API_URL="http://localhost:5000"

# Google Maps JavaScript API key for project-map auto-locate (geocoding).
# This ships in the browser bundle — that's expected for a Maps JS key — so it
# MUST be HTTP-referrer restricted to your domain(s) in Google Cloud Console,
# with the "Maps JavaScript API" and "Geocoding API" enabled and billing turned
# on for the project. Leave blank to disable auto-locate (developers can still
# drop the map pin manually).
VITE_GOOGLE_MAPS_API_KEY=""
